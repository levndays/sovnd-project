#!/usr/bin/env python3
import subprocess
import webbrowser
import time
import sys
import os
import requests
import signal

backend_proc = None

def start():
    global backend_proc
    print("🚀 Initializing SovND Security Environment...")
    
    uvicorn_path = os.path.expanduser("~/.local/bin/uvicorn")
    backend_proc = subprocess.Popen(
        [sys.executable, uvicorn_path, "src.api.main:app", "--port", "8000"],
        stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
    )
    
    time.sleep(2)
    
    print("🌍 Opening Command Center at http://localhost:8000")
    webbrowser.open("http://localhost:8000")
    
    print("\n✅ Dashboard running at http://localhost:8000")
    print("📋 Commands:")
    print("   python3 demo stop    - Stop the dashboard")
    print("   python3 demo attack - Demo: idle → attack → alert → idle")
    print("   Ctrl+C             - Stop everything")
    
    try:
        backend_proc.wait()
    except KeyboardInterrupt:
        stop()

def stop():
    global backend_proc
    if backend_proc:
        backend_proc.terminate()
        backend_proc.wait()
    subprocess.run(["pkill", "-f", "uvicorn"], capture_output=True)
    print("🛑 Dashboard stopped")

def attack_demo():
    global backend_proc
    print("🎯 Starting attack demo cycle...")
    
    if not backend_proc:
        uvicorn_path = os.path.expanduser("~/.local/bin/uvicorn")
        backend_proc = subprocess.Popen(
            [sys.executable, uvicorn_path, "src.api.main:app", "--port", "8000"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        time.sleep(2)
    
    base_url = "http://localhost:8000"
    
    # Phase 1: Idle
    print("  ① System IDLE - monitoring normal events...")
    time.sleep(3)
    
    # Phase 2: Attack
    print("  ② 🚨 LAUNCHING ATTACK! 🚨")
    try:
        requests.post(f"{base_url}/api/attack", timeout=5)
    except:
        pass
    time.sleep(1)
    
    # Phase 3: Threat detected
    print("  ③ ⚠️ THREAT DETECTED - logging alerts...")
    time.sleep(3)
    
    # Phase 4: Return to idle
    print("  ④ System returning to IDLE state...")
    print("\n✅ Demo cycle complete! Ready for next attack.")
    print("   Run 'python3 demo attack' again to repeat.")

if __name__ == "__main__":
    if len(sys.argv) > 1:
        cmd = sys.argv[1]
        if cmd == "start":
            start()
        elif cmd == "stop":
            stop()
        elif cmd == "attack":
            attack_demo()
        else:
            print("Usage: python3 demo [start|stop|attack]")
    else:
        print("Usage: python3 demo [start|stop|attack]")
        print("")
        print("  start   - Start dashboard and open browser")
        print("  stop    - Stop the dashboard")
        print("  attack  - Run idle→attack→alert→idle demo")