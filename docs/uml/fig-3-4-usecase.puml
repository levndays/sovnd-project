@startuml fig-3-4-usecase
'==========================================================================
' Рисунок 3.4 — Діаграма прецедентів системи оперативного виявлення
'               несанкціонованого доступу (СОВНД)
'
' Погляд сценаріїв використання (Use Case View) за моделлю 4+1.
' Тип діаграми: Use case diagram (UML 2.5).
'
' Напрямки залежностей за UML 2.5:
'   <<include>>: базовий UC ..> включений UC
'                (базовий завжди викликає включений)
'   <<extend>>:  розширювальний UC ..> базовий UC
'                (розширювальний УМОВНО виконується у точці розширення
'                 базового; стрілка вказує НА базовий)
'==========================================================================

skinparam shadowing false
skinparam defaultFontName "DejaVu Sans"
skinparam actorStyle awesome
left to right direction

' ── Актори ─────────────────────────────────────────────────────────
' Первинні (human) — стик-фігура
actor "Аналітик\nкібербезпеки" as Analyst
actor "DevOps-інженер" as DevOps

' Вторинні (system) — також зображені як актори, бо є джерелом/споживачем
' інформації за межами системи (UML 2.5 §16.3)
actor "Linux Kernel\n(eBPF subsystem)" as Kernel <<system>>
actor "Docker Engine" as Docker <<system>>

' ── Межа системи ───────────────────────────────────────────────────
rectangle "Система оперативного виявлення несанкціонованого доступу\n(СОВНД)" as System {

    usecase "UC-1\nЗапуск стенду та\nнакопичення базових\nліній поведінки" as UC1
    usecase "UC-2\nВиявлення аномалії\nв реальному часі" as UC2
    usecase "UC-3\nАдаптація профілю\nдо легітимних змін\nповедінки" as UC3
    usecase "UC-4\nАналіз контексту\nалерта через\nbreakdown та\nграф провенансу" as UC4

    ' Внутрішні «included» UCs — атомарні дії, що завжди виконуються
    ' як частина UC-2. Виділяю явно, щоб показати <<include>>-зв'язок.
    usecase "Зіставлення\ncgroup → container" as UCres
    usecase "Збереження алерта\nу SQLite" as UCsave
}

' ── Асоціації акторів із прецедентами ──────────────────────────────
DevOps  --> UC1
Analyst --> UC2
Analyst --> UC4
Kernel  --> UC2
Docker  --> UCres

' ── Включення (<<include>>): базовий UC завжди виконує включений ───
UC2 ..> UCres  : <<include>>
UC2 ..> UCsave : <<include>>

' ── Розширення (<<extend>>): стрілка від розширювального до базового
' Точки розширення вказують умови, за яких UC активується.
UC3 ..> UC1    : <<extend>>\n(extension point:\nдрифт базової лінії)
UC4 ..> UC2    : <<extend>>\n(extension point:\nалерт сформовано)

' ── Примітки для пояснення зв'язків (за UML 2.5 §16.3.4) ───────────
note bottom of UC3
  EWMA-схема (§2.1) автоматично
  підтягує μ_i, σ_i при поступовій
  зміні поведінки процесу — без
  ручного перенавчання.
end note

note bottom of UC4
  Аналітик переглядає breakdown
  (sig/stat/graph/ngram/P_ctx) та
  експорт графа через
  ProvenanceGraphBuilder.serialized()
  для зовнішньої візуалізації.
end note

@enduml
